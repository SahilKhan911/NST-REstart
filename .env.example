# Supabase — get these from supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Resend — get from resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=NST Restart <onboarding@resend.dev>

# WhatsApp counselling group invite link
NEXT_PUBLIC_WHATSAPP_GROUP_URL=

# Random secret used as the admin bearer token
ADMIN_TOKEN=
